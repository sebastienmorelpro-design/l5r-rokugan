  "obstacles": [],
  "lore": [
    {
      "titre": "Le salut (Rei)",
      "theme": "Politesse",
      "contenu": "Trois niveaux : saikeirei (45°, devant un supérieur impérial), futsurei (30°, égal ou supérieur de clan), eshaku (15°, simple courtoisie). Ne jamais détourner les yeux pendant le salut d'un supérieur, ni croiser son regard.",
      "id": "L17790543988120",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Adresse et titres",
      "theme": "Politesse",
      "contenu": "-sama (très respectueux, seigneur), -san (égal courtois), -dono (seigneur chaleureux), -kun (familier, jeune homme), -chan (intime). Utiliser un titre incorrect est une offense sérieuse.",
      "id": "L17790543988121",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Tatemae & Honne",
      "theme": "Politesse",
      "contenu": "Le visage public (tatemae) et le sentiment réel (honne) sont distincts. Un samouraï montre toujours tatemae en public. Révéler son honne est un signe d'intimité — ou de faiblesse.",
      "id": "L17790543988122",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Le refus impossible",
      "theme": "Politesse",
      "contenu": "Refuser frontalement est inconcevable. On répond par \"C'est difficile\" (mu zukashii), \"J'y réfléchirai\", ou un silence. L'art de la cour consiste à comprendre ces refus.",
      "id": "L17790543988123",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Cadeaux (Omiyage)",
      "theme": "Politesse",
      "contenu": "Offrir un cadeau lors d'une visite est obligatoire. La valeur compte moins que l'attention. Le destinataire le pose sans l'ouvrir devant l'invité, puis le réciproque plus tard.",
      "id": "L17790543988124",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Seppuku",
      "theme": "Rituels",
      "contenu": "Suicide rituel pour effacer le déshonneur. Vêtu de blanc, le samouraï rédige son poème de la mort (jisei), puis s'ouvre l'abdomen au wakizashi. Un second (kaishakunin) tranche la nuque. Ordonné (oibara) ou choisi (kanshi).",
      "id": "L17790543988125",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Genpuku",
      "theme": "Rituels",
      "contenu": "Cérémonie de passage à l'âge adulte (~15 ans). Reçoit son daisho, son nom d'adulte, présenté au daimyo. Suivi souvent du Tournoi de Topaze.",
      "id": "L17790543988126",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Mariage samouraï",
      "theme": "Rituels",
      "contenu": "San-san-kudo : les époux boivent trois fois dans trois coupes de saké, scellant l'union devant les ancêtres et un shugenja. Mariages arrangés par les chefs de famille.",
      "id": "L17790543988127",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Funérailles",
      "theme": "Rituels",
      "contenu": "Crémation. Les cendres reposent au mausolée familial. Période de deuil de 49 jours durant laquelle les proches portent du blanc et évitent les festivités.",
      "id": "L17790543988128",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Cha-no-yu (Cérémonie du thé)",
      "theme": "Cérémonies",
      "contenu": "Rituel précis hérité de Shinsei. Préparation, gestes et silences codifiés. Un seul faux geste révèle un samouraï mal éduqué. Souvent utilisée à la cour pour évaluer un visiteur.",
      "id": "L17790543988129",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Ikebana",
      "theme": "Cérémonies",
      "contenu": "Art floral. Trois branches symbolisent Ciel, Homme, Terre. Pratiqué surtout chez les Grues. Composition silencieuse, méditative.",
      "id": "L177905439881210",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Cérémonie d'investiture",
      "theme": "Cérémonies",
      "contenu": "Nomination officielle à une fonction (daimyo, magistrat). Devant son seigneur, le récipiendaire reçoit un objet symbolique (sceau, éventail, parchemin).",
      "id": "L177905439881211",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Bon Festival",
      "theme": "Festivités",
      "contenu": "Festival des morts (été). On allume des lanternes flottantes pour guider les esprits ancestraux qui reviennent visiter les vivants. Danses bon-odori.",
      "id": "L177905439881212",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Setsubun",
      "theme": "Festivités",
      "contenu": "Passage à la saison nouvelle (printemps). On lance des graines de soja en criant \"Oni wa soto, fuku wa uchi !\" (démons dehors, chance dedans). Important chez les Crabes.",
      "id": "L177905439881213",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Hanami",
      "theme": "Festivités",
      "contenu": "Contemplation des cerisiers en fleur (printemps). Picnics, poésie, philosophie sur la beauté éphémère (mono no aware). Très prisé des Grues.",
      "id": "L177905439881214",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Tournoi de Topaze",
      "theme": "Festivités",
      "contenu": "À Tsuma, chaque automne. Jeunes samouraïs récemment passés genpuku s'y affrontent. Vainqueur = Champion du Topaze + renommée immédiate.",
      "id": "L177905439881215",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Festival des Esprits Rivière",
      "theme": "Festivités",
      "contenu": "Apaisement des kami des rivières avant l'hiver (automne). Offrandes de riz et de saké jetées dans les eaux.",
      "id": "L177905439881216",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Shintao (Voie des Kami)",
      "theme": "Religion",
      "contenu": "Religion officielle. Vénération des Sept Fortunes (Bishamon, Benten, Daikoku, Ebisu, Fukurokujin, Hotei, Jurojin), des kami élémentaires, et des ancêtres. Shugenja = intermédiaires.",
      "id": "L177905439881217",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Voie de Shinsei",
      "theme": "Religion",
      "contenu": "Doctrine philosophique du Petit Maître Shinsei. Recherche de l'illumination par méditation, détachement, compréhension du Vide. Suivie par les moines (sohei, henshin).",
      "id": "L177905439881218",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Culte de Fu Leng",
      "theme": "Religion",
      "contenu": "Vénération du Neuvième Frère Tonnerre devenu Seigneur des Outrelands. Strictement interdit. Pratiqué par maho-tsukai et désespérés. Mène à la corruption inéluctable.",
      "visible": false,
      "descMJ": "Tous les pratiquants sont passibles de mort sans procès.",
      "id": "L177905439881219"
    },
    {
      "titre": "Bloodspeakers (Disciples d'Iuchiban)",
      "theme": "Religion",
      "contenu": "Secte secrète fondée par le shugenja maudit Iuchiban. Magie du sang (maho). Cherchent à libérer leur maître emprisonné. Cellules dans tout l'Empire.",
      "visible": false,
      "descMJ": "Iuchiban est enterré quelque part au sud, gardé par les Crabes. Difficile à détecter.",
      "id": "L177905439881220"
    },
    {
      "titre": "Le Conseil Impérial",
      "theme": "Politique",
      "contenu": "Cinq Conseillers Élémentaires (Isawa traditionnellement) conseillent l'Empereur. Le Champion d'Émeraude commande la justice et l'armée. Le Chancelier gère l'administration.",
      "id": "L177905439881221",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Le Champion d'Émeraude",
      "theme": "Politique",
      "contenu": "Plus haute fonction militaire après l'Empereur. Choisi par tournoi tous les cinq ans. Autorité directe du Trône.",
      "id": "L177905439881222",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Les Magistrats d'Émeraude",
      "theme": "Politique",
      "contenu": "Force de loi impériale, indépendante des clans. Voyagent à travers Rokugan pour faire respecter les édits de l'Empereur.",
      "id": "L177905439881223",
      "descMJ": "",
      "visible": true
    },
    {
      "titre": "Les Kolat",
      "theme": "Politique",
      "contenu": "Conspiration séculaire visant à renverser le système impérial. Pensent que samouraïs et Fortunes oppriment l'humanité. Recrutent dans tous les clans.",
      "visible": false,
      "descMJ": "Dix Maîtres dirigent l'organisation. Pénétrent tous les clans. Méfiance constante recommandée.",
      "id": "L177905439881224"
    },
    {
      "titre": "Le Goju (Ninja de l'Ombre)",
      "theme": "Politique",
      "contenu": "Ordre secret de ninjas serviteurs de la Mère Sombre. Liens directs avec les Outrelands. Peuvent se déplacer dans les ombres elles-mêmes.",
      "visible": false,
      "descMJ": "Très rares mais redoutables. Frappent parfois au cœur même de la capitale.",
      "id": "L177905439881225"
    },
    {
      "titre": "L'Ordre des Faucons",
      "theme": "Politique",
      "contenu": "Société secrète de bushi indépendants traquant les corrupteurs (maho, Bloodspeakers). Reconnaissables à un tatouage de faucon caché.",
      "visible": false,
      "descMJ": "Demi-officiel, toléré tant qu'ils restent discrets. Alliés discrets de certains Crabes et Phénix.",
      "id": "L177905439881226"
    },
    {
      "titre": "Les Sceaux Naga",
      "theme": "Religion",
      "contenu": "Sept sceaux mystiques scellent le sommeil des Naga dans Shinomen. Si tous étaient brisés, le peuple-serpent se réveillerait.",
      "visible": false,
      "descMJ": "Trois sceaux ont déjà été affaiblis par l'âge. Le réveil approche.",
      "id": "L177905439881227"
    }
  ],
